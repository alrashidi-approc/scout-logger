# scout-logger — single config file (copy to .env)

# HTTP server
HOST=0.0.0.0
# Use 8081 while old logplatform still runs on 8080; switch to 8080 after cutover
PORT=8081
PUBLIC_URL=http://46.62.217.25:8081
DASHBOARD_API_KEY=change-me-dashboard-key
DASHBOARD_WEB_PATH=scout/dashboard

# PostgreSQL — server uses POSTGRES_* (supports special chars like # in password).
# DATABASE_URL is optional fallback only.
POSTGRES_USER=scout
POSTGRES_PASSWORD=change-me
POSTGRES_DB=scout
# Host port only when using docker-compose.dev.yaml (default 5433 — avoids conflict with system Postgres)
DB_PORT=5433

# Hetzner deploy (./deploy)
HETZNER_HOST=root@46.62.217.25
HETZNER_DIR=/opt/scout-logger
# HETZNER_SSH_KEY=~/.ssh/id_ed25519
# HETZNER_SSH_PORT=22

