# scout-logger — copy to .env and edit. Never commit .env.

# HTTP server
HOST=0.0.0.0
PORT=8080
PUBLIC_URL=http://localhost:8080
DASHBOARD_API_KEY=change-me-dashboard-key
DASHBOARD_WEB_PATH=scout/dashboard

# PostgreSQL (server reads POSTGRES_*; Docker dev maps DB_PORT to host)
POSTGRES_USER=scout
POSTGRES_PASSWORD=change-me
POSTGRES_DB=scout
DB_PORT=5433

# Deploy (./deploy) — optional
# HETZNER_HOST=root@your-server
# HETZNER_DIR=/opt/scout-logger
# HETZNER_SSH_KEY=~/.ssh/id_ed25519

# Auth (dashboard users)
JWT_SECRET=change-me-jwt-secret-min-32-chars
ENCRYPTION_KEY=change-me-encryption-key-min-32-chars

# Email verification — NOT required. Leave SMTP empty and accounts are verified on signup.
# Only add these later if you want real verification emails:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com

# Mobile DSN is shown in the dashboard after you create a project — not stored here.
